# ---------------------------------------------------------------------------
# CryptoPolio — server environment variables
# Copy this file to `.env` and fill in real values.
# ---------------------------------------------------------------------------

# Port the API listens on. Hosting platforms (Render, etc.) inject their own.
PORT=5000

# Set to "production" when deploying. In production, JWT_SECRET and
# DATABASE_URI become mandatory and the server refuses to start without them.
NODE_ENV=development

# Secret used to sign JWT auth tokens. REQUIRED in production.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me

# MongoDB connection string. REQUIRED in production.
# In development, leaving this blank starts a throwaway in-memory database.
DATABASE_URI=

# Comma-separated list of allowed frontend origins (CORS).
# Localhost origins are always permitted for local development.
CLIENT_URL=https://your-frontend.vercel.app
