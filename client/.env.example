# ---------------------------------------------------------------------------
# CryptoPolio — client environment variables
# Copy this file to `.env.local` and fill in real values.
# ---------------------------------------------------------------------------

# Base URL of the backend API.
# Leave unset for local development — the client auto-detects localhost and
# talks to http://localhost:5000. Set this for production builds.
NEXT_PUBLIC_BASE_URL=https://your-backend.onrender.com
